generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  NEW
  PAID
  ON_THE_WAY
  COMPLETED
  CANCELED
}

enum UlaanbaatarDistrict {
  BAYANZURKH
  KHAN_UUL
  SONGINOKHAIRKHAN
  BAYANGOL
  SUKHMBAATAR
  CHINGELTEI
  NALAIKH
  BAGANUUR
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  isAdmin        Boolean        @default(false)
  createdAt      DateTime       @default(now())
  orders         Order[]
  savedAddresses SavedAddress[]
}

model SavedAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  city      String
  district  String
  khoroo    String
  detail    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Category {
  slug     String    @id
  name     String
  products Product[]
}

model Product {
  id            String          @id
  name          String
  price         Float
  originalPrice Float?
  image         String
  categorySlug  String
  category      Category        @relation(fields: [categorySlug], references: [slug])
  rating        Float           @default(0)
  stock         Int             @default(0)
  isNew         Boolean         @default(false)
  isFeatured    Boolean         @default(false)
  isBundle      Boolean         @default(false)
  unit          String?
  flavors       ProductFlavor[]
  orderItems    OrderItem[]
  bundleItems   BundleItem[]    @relation("BundleParent")
  inBundles     BundleItem[]    @relation("BundleChild")
}

model ProductFlavor {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  flavorName String
  stock      Int     @default(0)
}

model BundleItem {
  id             String  @id @default(cuid())
  parentBundleId String
  parentBundle   Product @relation("BundleParent", fields: [parentBundleId], references: [id], onDelete: Cascade)
  childProductId String
  childProduct   Product @relation("BundleChild", fields: [childProductId], references: [id])
  quantity       Int     @default(1)
}

model Order {
  id              String              @id
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  createdAt       DateTime            @default(now())
  items           OrderItem[]
  custFirstName   String
  custLastName    String
  phonePrimary    String
  phoneSecondary  String
  district        UlaanbaatarDistrict
  khoroo          String
  detailedAddress String
  receiptImageUrl String?
  paymentMethod   String              @default("BANK_TRANSFER")
  subtotal        Float
  discount        Float               @default(0)
  delivery        Float
  ecoBag          Float
  total           Float
  status          OrderStatus         @default(NEW)
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  qty       Int
  price     Float
  flavor    String?
}
